# ====================================================================
#  Пример файла переменных окружения для Grow-a-Garden раздача-бота.
#  Скопируйте этот файл в `.env` и заполните своими значениями:
#      cp .env.example .env
# ====================================================================

# --- ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ ---

# Токен бота от @BotFather
BOT_TOKEN=123456789:AAExampleBotTokenReplaceMeWithYourRealToken

# Telegram ID администратора (можно несколько через запятую: 111,222,333).
# Узнать свой ID можно у бота @userinfobot.
ADMIN_ID=123456789

# Канал для проверки подписки.
#   - публичный: @channel_username
#   - приватный/супергруппа: числовой ID, например -1001234567890
# Бот должен быть администратором канала с правом чтения участников.
CHANNEL_ID=@your_channel_username

# Ссылка на приватный сервер Roblox (Grow a Garden).
# Используется как значение по умолчанию при первом запуске.
# Позже её можно изменить через админ-панель без правки кода.
SERVER_LINK=https://www.roblox.com/share?code=your_private_server_code

# --- НЕОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ ---

# Публичная ссылка на канал (для кнопки «Подписаться»).
# Если не задано — кнопка не показывается.
CHANNEL_LINK=https://t.me/your_channel_username

# Шанс выигрыша (от 0 до 1). По умолчанию 0.25 (25%).
WIN_CHANCE=0.25

# Сколько бесплатных попыток выдавать новым пользователям. По умолчанию 1.
FREE_ATTEMPTS=1
